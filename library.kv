ScreenManager:
    LoginScreen:
        name: "login"
    DashboardScreen:
        name: "dashboard"
    BookScreen:
        name: "books"
    IssueScreen:
        name: "issue"
    IssuedBooksScreen:
        name: "issued"

<StyledButton@Button>:
    background_normal: ''
    background_down: ''
    background_color: 0.12, 0.56, 0.95, 1
    color: 1, 1, 1, 1
    font_size: '16sp'
    bold: True
    size_hint_y: None
    height: 52
    canvas.before:
        Color:
            rgba: self.background_color
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [16]

<AltButton@StyledButton>:
    background_color: 0.24, 0.30, 0.44, 1

<StyledTextInput@TextInput>:
    background_normal: ''
    background_active: ''
    foreground_color: 1, 1, 1, 1
    cursor_color: 1, 1, 1, 1
    background_color: 0.12, 0.16, 0.24, 1
    padding: [18, 14]
    font_size: '16sp'
    size_hint_y: None
    height: 52
    multiline: False
    hint_text_color: 0.76, 0.80, 0.92, 1
    halign: 'left'

<HeaderLabel@Label>:
    color: 1, 1, 1, 1
    font_size: '28sp'
    bold: True
    size_hint_y: None
    height: self.texture_size[1] + 10

<BaseScreen@BoxLayout>:
    orientation: 'vertical'
    spacing: 16
    padding: [20, 18, 20, 20]
    canvas.before:
        Color:
            rgba: 0.08, 0.10, 0.14, 1
        Rectangle:
            pos: self.pos
            size: self.size

<LoginScreen>:
    BaseScreen:
        spacing: 24

        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: 180
            padding: [24, 24, 24, 24]
            canvas.before:
                Color:
                    rgba: 0.12, 0.17, 0.24, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [24]

            Label:
                text: 'Library Management'
                color: 1, 1, 1, 1
                font_size: '34sp'
                bold: True
                halign: 'left'
                valign: 'middle'
                text_size: self.size

            Label:
                text: 'Secure login for staff and library administrators.'
                color: 0.72, 0.78, 0.92, 1
                font_size: '15sp'
                halign: 'left'
                valign: 'middle'
                text_size: self.size

        StyledTextInput:
            id: username
            hint_text: 'Username'

        StyledTextInput:
            id: password
            hint_text: 'Password'
            password: True

        StyledButton:
            text: 'LOGIN'
            on_press: root.login()

        Label:
            id: login_status
            text: ''
            color: 1, 0.42, 0.42, 1
            font_size: '14sp'
            size_hint_y: None
            height: self.texture_size[1]

<DashboardScreen>:
    BaseScreen:
        HeaderLabel:
            text: 'Dashboard'

        GridLayout:
            cols: 3
            spacing: 14
            size_hint_y: None
            height: 140

            BoxLayout:
                orientation: 'vertical'
                padding: [18, 14]
                canvas.before:
                    Color:
                        rgba: 0.22, 0.58, 0.96, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [18]
                Label:
                    text: 'Total Books'
                    color: 1, 1, 1, 1
                    font_size: '14sp'
                Label:
                    id: total_books
                    text: '0'
                    color: 1, 1, 1, 1
                    font_size: '28sp'
                    bold: True

            BoxLayout:
                orientation: 'vertical'
                padding: [18, 14]
                canvas.before:
                    Color:
                        rgba: 0.21, 0.84, 0.42, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [18]
                Label:
                    text: 'Issued'
                    color: 1, 1, 1, 1
                    font_size: '14sp'
                Label:
                    id: issued_books
                    text: '0'
                    color: 1, 1, 1, 1
                    font_size: '28sp'
                    bold: True

            BoxLayout:
                orientation: 'vertical'
                padding: [18, 14]
                canvas.before:
                    Color:
                        rgba: 1, 0.59, 0.24, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [18]
                Label:
                    text: 'Available'
                    color: 1, 1, 1, 1
                    font_size: '14sp'
                Label:
                    id: available_books
                    text: '0'
                    color: 1, 1, 1, 1
                    font_size: '28sp'
                    bold: True

        BoxLayout:
            orientation: 'vertical'
            spacing: 12
            size_hint_y: None
            height: 250

            StyledButton:
                text: 'Books Management'
                on_press: app.root.current = 'books'

            StyledButton:
                text: 'Issue Book'
                on_press: app.root.current = 'issue'

            StyledButton:
                text: 'Issued Books'
                on_press: app.root.current = 'issued'

        Widget:

        AltButton:
            text: 'Logout'
            on_press: app.root.current = 'login'

<BookScreen>:
    BaseScreen:
        HeaderLabel:
            text: 'Books Management'

        StyledTextInput:
            id: book_title
            hint_text: 'Book Title'

        StyledTextInput:
            id: book_author
            hint_text: 'Author Name'

        StyledTextInput:
            id: book_quantity
            hint_text: 'Quantity'
            input_filter: 'int'

        StyledButton:
            text: 'Add Book'
            on_press: root.add_book()

        StyledButton:
            text: 'View Books'
            on_press: root.view_books()

        ScrollView:
            do_scroll_x: False
            bar_width: 8
            scroll_type: ['bars', 'content']

            Label:
                id: book_status
                text: ''
                color: 0.90, 0.90, 0.95, 1
                size_hint_y: None
                text_size: self.width, None
                height: self.texture_size[1]
                halign: 'left'
                valign: 'top'

        AltButton:
            text: 'Back to Dashboard'
            on_press: app.root.current = 'dashboard'

<IssueScreen>:
    BaseScreen:
        HeaderLabel:
            text: 'Issue Book'

        StyledTextInput:
            id: student_name
            hint_text: 'Student Name'

        StyledTextInput:
            id: father_name
            hint_text: 'Father Name'

        StyledTextInput:
            id: student_class
            hint_text: 'Class'

        StyledTextInput:
            id: roll_no
            hint_text: 'Roll Number'

        StyledTextInput:
            id: issue_book_name
            hint_text: 'Book Name'

        StyledButton:
            text: 'Issue Book'
            on_press: root.issue_book()

        Label:
            id: issue_status
            text: ''
            color: 0.90, 0.90, 0.95, 1
            font_size: '15sp'
            size_hint_y: None
            height: self.texture_size[1]
            text_size: self.width, None
            halign: 'left'
            valign: 'middle'

        AltButton:
            text: 'Back to Dashboard'
            on_press: app.root.current = 'dashboard'

<IssuedBooksScreen>:
    BaseScreen:
        HeaderLabel:
            text: 'Issued Books'

        StyledButton:
            text: 'Show Issued Books'
            on_press: root.show_issued_books()

        ScrollView:
            do_scroll_x: False
            bar_width: 8
            scroll_type: ['bars', 'content']

            Label:
                id: issued_label
                text: ''
                color: 0.90, 0.90, 0.95, 1
                size_hint_y: None
                text_size: self.width, None
                height: self.texture_size[1]
                halign: 'left'
                valign: 'top'

        AltButton:
            text: 'Back to Dashboard'
            on_press: app.root.current = 'dashboard'
